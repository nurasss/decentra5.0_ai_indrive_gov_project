# ZanAi / LexMirror — Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── OpenAI API ───────────────────────────────────────────────────────────────
# Required: get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# LLM model used for the judge (chain-of-thought legal analysis)
OPENAI_LLM_MODEL=gpt-4.1-mini

# Embedding model used for vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Request timeout in seconds
OPENAI_TIMEOUT_SEC=60

# ─── NLI Model ────────────────────────────────────────────────────────────────
# Russian BERT for Natural Language Inference (baseline layer)
# Default: cointegrated/rubert-base-cased-nli-threeway
# NLI_MODEL=cointegrated/rubert-base-cased-nli-threeway

# ─── Retry / Backoff ──────────────────────────────────────────────────────────
# OPENAI_MAX_RETRIES=3
# OPENAI_RETRY_BACKOFF_SEC=0.6
